generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  STUDENT
  FACULTY
  HOD
  ADMIN
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ──────────────────────────────────────────────
// Hierarchical Organization Models
// ──────────────────────────────────────────────

model Branch {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique // e.g. "CSE", "IT"
  semesters Semester[]
  users     User[]
  courses   Course[]
}

model Semester {
  id        String     @id @default(cuid())
  number    Int        // e.g. 1 to 8
  branchId  String
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  divisions Division[]
  users     User[]

  @@unique([number, branchId])
}

model Division {
  id               String           @id @default(cuid())
  name             String           // e.g. "A", "B"
  semesterId       String
  semester         Semester         @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  batches          Batch[]
  users            User[]
  timetableEntries TimetableEntry[]

  @@unique([name, semesterId])
}

model Batch {
  id               String           @id @default(cuid())
  name             String           // e.g. "B1", "B2"
  divisionId       String
  division         Division         @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  users            User[]
  timetableEntries TimetableEntry[]

  @@unique([name, divisionId])
}

// ──────────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  passwordHash String
  department   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Organizational Relations
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  semesterId   String?
  semester     Semester?  @relation(fields: [semesterId], references: [id])
  divisionId   String?
  division     Division?  @relation(fields: [divisionId], references: [id])
  batchId      String?
  batch        Batch?     @relation(fields: [batchId], references: [id])

  timetableEntries TimetableEntry[]   @relation("FacultyTimetable")
  sessions         Session[]          @relation("FacultySession")
  attendanceMarked AttendanceRecord[] @relation("MarkedBy")
  attendanceRecords AttendanceRecord[]
  editLogs         EditLog[]          @relation("EditedBy")
  createdEvents    Event[]            @relation("EventCreator")
  eventScopes      EventScopeItem[]
  savedGroupOwned  SavedGroup[]       @relation("SavedGroupCreator")
  savedGroupMember SavedGroupMember[]
}

model Course {
  id         String @id @default(cuid())
  code       String @unique
  name       String
  department String?
  branchId   String
  credits    Int    @default(3)

  branch           Branch            @relation(fields: [branchId], references: [id])
  timetableEntries TimetableEntry[]
  sessions         Session[]
}

model TimetableEntry {
  id         String   @id @default(cuid())
  dayOfWeek  Int
  startTime  DateTime
  endTime    DateTime
  courseId   String
  facultyId  String
  room       String
  section    String?
  divisionId String
  batchId    String? // Null means entire division

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty  User      @relation("FacultyTimetable", fields: [facultyId], references: [id], onDelete: Cascade)
  division Division  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  batch    Batch?    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sessions Session[]
}

model Session {
  id               String        @id @default(cuid())
  timetableEntryId String?
  courseId         String
  facultyId        String
  date             DateTime      @db.Date
  startTime        DateTime?
  endTime          DateTime?
  status           SessionStatus @default(SCHEDULED)
  qrToken          String?       @unique
  isAdHoc          Boolean       @default(false)
  createdAt        DateTime      @default(now())

  timetableEntry    TimetableEntry?    @relation(fields: [timetableEntryId], references: [id])
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty           User               @relation("FacultySession", fields: [facultyId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus
  markedAt   DateTime         @default(now())
  markedById String

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  markedBy User    @relation("MarkedBy", fields: [markedById], references: [id])
  student  User    @relation(fields: [studentId], references: [id])

  editLogs EditLog[]

  @@unique([sessionId, studentId])
}

model EditLog {
  id                 String           @id @default(cuid())
  attendanceRecordId String
  oldStatus          AttendanceStatus
  newStatus          AttendanceStatus
  editedById         String
  editedAt           DateTime         @default(now())
  reason             String?

  attendanceRecord AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  editedBy         User             @relation("EditedBy", fields: [editedById], references: [id])
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

enum EventScopeType {
  DEPARTMENT
  SAVED_GROUP
  CUSTOM_LIST
}

model Event {
  id          String         @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  scopeType   EventScopeType
  department  String?        // Legacy compatibility or update to branchId
  createdById String
  isApplied   Boolean        @default(false)
  createdAt   DateTime       @default(now())

  createdBy   User             @relation("EventCreator", fields: [createdById], references: [id])
  scopeItems  EventScopeItem[]
  savedGroup  SavedGroup?      @relation(fields: [savedGroupId], references: [id])
  savedGroupId String?
}

model EventScopeItem {
  id        String @id @default(cuid())
  eventId   String
  studentId String

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
}

model SavedGroup {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy User              @relation("SavedGroupCreator", fields: [createdById], references: [id])
  members   SavedGroupMember[]
  events    Event[]
}

model SavedGroupMember {
  id           String @id @default(cuid())
  savedGroupId String
  studentId    String

  savedGroup SavedGroup @relation(fields: [savedGroupId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([savedGroupId, studentId])
}
