generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  STUDENT
  FACULTY
  HOD
  ADMIN
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  passwordHash String
  department   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  timetableEntries TimetableEntry[]   @relation("FacultyTimetable")
  sessions         Session[]          @relation("FacultySession")
  attendanceMarked AttendanceRecord[] @relation("MarkedBy")
  editLogs         EditLog[]          @relation("EditedBy")
  createdEvents    Event[]            @relation("EventCreator")
  eventScopes      EventScopeItem[]
  savedGroupOwned  SavedGroup[]       @relation("SavedGroupCreator")
  savedGroupMember SavedGroupMember[]
}

model Course {
  id         String @id @default(cuid())
  code       String @unique
  name       String
  department String
  credits    Int    @default(3)

  timetableEntries TimetableEntry[]
  sessions         Session[]
}

model TimetableEntry {
  id        String   @id @default(cuid())
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  courseId  String
  facultyId String
  room      String
  section   String

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty  User      @relation("FacultyTimetable", fields: [facultyId], references: [id], onDelete: Cascade)
  sessions Session[]
}

model Session {
  id               String        @id @default(cuid())
  timetableEntryId String?
  courseId         String
  facultyId        String
  date             DateTime      @db.Date
  startTime        DateTime?
  endTime          DateTime?
  status           SessionStatus @default(SCHEDULED)
  qrToken          String?       @unique
  isAdHoc          Boolean       @default(false)
  createdAt        DateTime      @default(now())

  timetableEntry    TimetableEntry?    @relation(fields: [timetableEntryId], references: [id])
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty           User               @relation("FacultySession", fields: [facultyId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus
  markedAt   DateTime         @default(now())
  markedById String

  session  Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  markedBy User    @relation("MarkedBy", fields: [markedById], references: [id])

  editLogs EditLog[]

  @@unique([sessionId, studentId])
}

model EditLog {
  id                 String           @id @default(cuid())
  attendanceRecordId String
  oldStatus          AttendanceStatus
  newStatus          AttendanceStatus
  editedById         String
  editedAt           DateTime         @default(now())
  reason             String?

  attendanceRecord AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  editedBy         User             @relation("EditedBy", fields: [editedById], references: [id])
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

enum EventScopeType {
  DEPARTMENT
  SAVED_GROUP
  CUSTOM_LIST
}

model Event {
  id          String         @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  scopeType   EventScopeType
  department  String?        // Used when scopeType is DEPARTMENT
  createdById String
  isApplied   Boolean        @default(false)
  createdAt   DateTime       @default(now())

  createdBy   User             @relation("EventCreator", fields: [createdById], references: [id])
  scopeItems  EventScopeItem[]
  savedGroup  SavedGroup?      @relation(fields: [savedGroupId], references: [id])
  savedGroupId String?
}

model EventScopeItem {
  id        String @id @default(cuid())
  eventId   String
  studentId String

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
}

model SavedGroup {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy User              @relation("SavedGroupCreator", fields: [createdById], references: [id])
  members   SavedGroupMember[]
  events    Event[]
}

model SavedGroupMember {
  id           String @id @default(cuid())
  savedGroupId String
  studentId    String

  savedGroup SavedGroup @relation(fields: [savedGroupId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([savedGroupId, studentId])
}
